rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- User Data Match Blocks ---
    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && 
        incoming().keys().hasAll(['skinType', 'hairType']) &&
        incoming().size() >= 2;
      allow update: if isOwner(userId);

      // Sub-collections
      
      match /progress/{entryId} {
        allow read: if isOwner(userId);
        allow create, update: if isOwner(userId) && isValidId(entryId);
        allow delete: if isOwner(userId);
      }
      
      match /logs/{logId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(logId);
      }
      
      match /reminders/{reminderId} {
        allow read: if isOwner(userId);
        allow write: if isOwner(userId) && isValidId(reminderId);
      }

      match /roadmap/{docId} {
        allow read, write: if isOwner(userId) && isValidId(docId);
      }
    }
  }
}
